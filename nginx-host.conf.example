# Serverning o'z nginx konfiguratsiyasi (Docker tashqarisida)
# /etc/nginx/sites-available/bahrombek.uz ga nusxalang
# keyin: sudo ln -s /etc/nginx/sites-available/bahrombek.uz /etc/nginx/sites-enabled/

server {
    listen 80;
    server_name bahrombek.uz www.bahrombek.uz;

    # Let's Encrypt uchun
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # HTTP → HTTPS yo'naltirish
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name bahrombek.uz www.bahrombek.uz;

    ssl_certificate     /etc/letsencrypt/live/bahrombek.uz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/bahrombek.uz/privkey.pem;

    # Docker container ga proxy (APP_PORT=8080 bo'lsa)
    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
